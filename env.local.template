# Copy to `.env.local` in this folder (gitignored), then fill in:
#
#   cp env.local.template .env.local
#
NGX_PULSE_API_KEY=
OPENAI_API_KEY=

# Optional override (default: https://www.ngxpulse.ng)
# NGX_PULSE_BASE_URL=https://www.ngxpulse.ng

# Supabase (safe in the browser — publishable/anon key only, never service_role)
# VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# VITE_SUPABASE_PUBLISHABLE_KEY=
# Supabase Dashboard → Authentication → Providers → Email (on) for top-bar Sign in

# Storage bucket for PDF archives (SQL): supabase/migrations/20260406170000_rag_pdf_storage.sql

# Docker API: npm run docker:up  (needs Docker Desktop; uses this file as env_file)

# Server-only (RAG ingest + retrieval). From Supabase Dashboard → Settings → API.
# SUPABASE_SERVICE_ROLE_KEY=
# Optional alias if you do not use VITE_ URL on the server:
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
